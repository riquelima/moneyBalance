<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cartão Nubank</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #f0f0f3;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      font-family: 'Inter', -apple-system, sans-serif;
      padding: 20px;
    }

    .card {
      position: relative;
      width: 480px;
      height: 303px;
      border-radius: 22px;
      background: linear-gradient(135deg, #9b30d0 0%, #8a2be0 45%, #7d1fc4 100%);
      box-shadow: 0 18px 50px rgba(120,30,180,0.35), 0 4px 14px rgba(0,0,0,0.18);
      overflow: hidden;
      color: #fff;
    }

    /* subtle diagonal sheen */
    .card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(115deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0) 40%);
      pointer-events: none;
    }

    /* ── Mastercard logo ── */
    .mastercard {
      position: absolute;
      top: 28px;
      right: 30px;
      text-align: center;
    }
    .mc-circles {
      position: relative;
      width: 118px;
      height: 74px;
      margin: 0 auto;
    }
    .mc-circle {
      position: absolute;
      top: 0;
      width: 74px;
      height: 74px;
      border-radius: 50%;
    }
    .mc-red    { left: 0;  background: #eb001b; }
    .mc-yellow { right: 0; background: #f79e1b; }
    /* overlap blend */
    .mc-overlap {
      position: absolute;
      left: 50%;
      top: 0;
      transform: translateX(-50%);
      width: 44px;
      height: 74px;
      background: #ff5f00;
      border-radius: 50% / 50%;
    }
    .mc-text {
      font-size: 26px;
      font-weight: 500;
      letter-spacing: -0.5px;
      margin-top: 6px;
      color: #fff;
    }
    .mc-text sup { font-size: 9px; font-weight: 400; }

    /* ── Chip ── */
    .chip {
      position: absolute;
      left: 52px;
      top: 104px;
      width: 66px;
      height: 50px;
      border-radius: 9px;
      background: linear-gradient(135deg, #d9d4e0 0%, #c3bcd0 100%);
      border: 1px solid rgba(120,80,150,0.5);
    }
    .chip svg { width: 100%; height: 100%; }

    /* ── Contactless ── */
    .contactless {
      position: absolute;
      left: 134px;
      top: 110px;
      width: 34px;
      height: 38px;
    }
    .contactless svg { width: 100%; height: 100%; }

    /* ── Nu logo + name ── */
    .bottom {
      position: absolute;
      left: 52px;
      bottom: 56px;
      display: flex;
      align-items: center;
      gap: 22px;
    }
    .nu-logo { width: 74px; height: 60px; }
    .card-name {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: 2px;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="card">

    <!-- Mastercard -->
    <div class="mastercard">
      <div class="mc-circles">
        <div class="mc-circle mc-red"></div>
        <div class="mc-circle mc-yellow"></div>
        <div class="mc-overlap"></div>
      </div>
      <div class="mc-text">mastercard<sup>®</sup></div>
    </div>

    <!-- Chip -->
    <div class="chip">
      <svg viewBox="0 0 66 50" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="1" width="64" height="48" rx="8" fill="none" stroke="#7a5096" stroke-width="1.2"/>
        <!-- center pad -->
        <ellipse cx="33" cy="25" rx="16" ry="13" fill="#cfc8da" stroke="#9a8fb0" stroke-width="1"/>
        <circle cx="33" cy="12" r="3" fill="#cfc8da" stroke="#9a8fb0" stroke-width="0.8"/>
        <!-- contact lines -->
        <line x1="1" y1="25" x2="17" y2="25" stroke="#9a8fb0" stroke-width="1.2"/>
        <line x1="49" y1="25" x2="65" y2="25" stroke="#9a8fb0" stroke-width="1.2"/>
        <line x1="33" y1="38" x2="33" y2="49" stroke="#9a8fb0" stroke-width="1.2"/>
        <line x1="17" y1="12" x2="17" y2="38" stroke="#9a8fb0" stroke-width="1.2"/>
        <line x1="49" y1="12" x2="49" y2="38" stroke="#9a8fb0" stroke-width="1.2"/>
      </svg>
    </div>

    <!-- Contactless -->
    <div class="contactless">
      <svg viewBox="0 0 34 38" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" xmlns="http://www.w3.org/2000/svg">
        <path d="M6 9 a16 16 0 0 1 0 20"/>
        <path d="M13 5 a24 24 0 0 1 0 28"/>
        <path d="M20 1 a32 32 0 0 1 0 36"/>
      </svg>
    </div>

    <!-- Nu logo + nome -->
    <div class="bottom">
      <svg class="nu-logo" viewBox="0 0 74 60" fill="none" stroke="#fff" stroke-width="4.2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
        <!-- 'n' -->
        <path d="M6 54 V18 a12 12 0 0 1 24 0 V54"/>
        <!-- 'u' (slightly taller, descending tail) -->
        <path d="M40 6 V42 a12 12 0 0 0 24 0 V6"/>
      </svg>
      <span class="card-name">HENRIQUE LIMA</span>
    </div>

  </div>
</body>
</html>